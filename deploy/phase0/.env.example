# Copy this file to .env on the Oracle server and edit the values.

# Use URL-safe characters for POSTGRES_PASSWORD because Phoenix uses it in a database URL.
POSTGRES_PASSWORD=replace_with_a_long_random_url_safe_password
N8N_ENCRYPTION_KEY=replace_with_32_plus_random_chars
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace_with_a_long_random_password
PHOENIX_ADMIN_PASSWORD=replace_with_a_long_random_password

GENERIC_TIMEZONE=America/Chicago

# Phase 0 binds services to localhost. Access them with SSH tunnels.
N8N_PORT=5678
PHOENIX_UI_PORT=6006
PHOENIX_GRPC_PORT=4317
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334
