      "inlineEmojis": []
    },
    {
      "id": "1450630698791600301",
      "type": "Default",
      "timestamp": "2025-12-16T17:28:30.007-06:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Another example I’ve seen is strong impact when TPMs help translate execution into external stories, example contributing to blogs, case studies, or conference talks that explain how complex systems were built or scaled. That combination of solid execution plus storytelling builds trust.",
      "author": {
        "id": "921916180309086250",
        "name": "illusionustpanda",
        "discriminator": "0000",
