# Local-only n8n API settings for scripts/n8n-sync.js.
# Copy to .env.local and fill in your real API key. Do not commit .env.local.

# Use the repo-owned n8n SSH tunnel from your laptop:
# ssh -i "$HOME\mykey.key" -L 5679:127.0.0.1:5679 ubuntu@discord-notifier.duckdns.org
N8N_API_URL=http://127.0.0.1:5679/api/v1
N8N_API_KEY=replace_with_n8n_personal_api_key
